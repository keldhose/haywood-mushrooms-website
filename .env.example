# Required for the contact form (app/api/contact) to send email via Resend.
# Sign up at https://resend.com, create an API key, and set it here / in your
# hosting provider's environment variables.
RESEND_API_KEY=

# Optional: the "from" address used when sending contact form emails.
# Must be from a domain you've verified in Resend, or leave unset to use
# Resend's sandbox address (onboarding@resend.dev) for testing.
CONTACT_FROM_EMAIL=

# Firebase client config — from Firebase Console > Project settings > Your apps.
# Public/safe to expose in the browser bundle.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK — from a service account JSON (Project settings >
# Service accounts > Generate new private key). SECRET — do not commit.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe — from the Stripe dashboard (Developers > API keys / Webhooks).
# Use test-mode keys (sk_test_...) until ready to accept real payments.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Shippo — from goshippo.com (Settings > API). Used for live shipping rates.
SHIPPO_API_KEY=
