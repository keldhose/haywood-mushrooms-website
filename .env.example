# Required for the contact form (app/api/contact) to send email via Resend.
# Sign up at https://resend.com, create an API key, and set it here / in your
# hosting provider's environment variables.
RESEND_API_KEY=

# Optional: the "from" address used when sending contact form emails.
# Must be from a domain you've verified in Resend, or leave unset to use
# Resend's sandbox address (onboarding@resend.dev) for testing.
CONTACT_FROM_EMAIL=
